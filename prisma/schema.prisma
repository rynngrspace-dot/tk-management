generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  classId   String?
  studentId Int?
  class     Class?   @relation("ClassTeachers", fields: [classId], references: [id])
  student   Student? @relation("StudentParents", fields: [studentId], references: [id], onDelete: Cascade)
}

model Class {
  id        String    @id
  name      String    @map("class")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  students  Student[]
  teachers  User[]    @relation("ClassTeachers")
}

model Student {
  id             Int              @id @default(autoincrement())
  nis            String           @unique
  name           String
  classId        String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  address        String?
  allergies      String?
  dateOfBirth    DateTime?
  gender         String?
  parentName     String?
  parentPhone    String?
  sawResults     SawResult[]
  class          Class            @relation(fields: [classId], references: [id])
  parents        User[]           @relation("StudentParents")
  weeklyProgress WeeklyProgress[]
}

model Criteria {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  name        String
  weight      Float
  type        String       @default("benefit")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assessments Assessment[]
}

model WeeklyProgress {
  id          Int          @id @default(autoincrement())
  studentId   Int
  week        Int
  month       String
  year        Int
  note        String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assessments Assessment[]
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, week, month, year])
}

model Assessment {
  id               Int            @id @default(autoincrement())
  weeklyProgressId Int
  criteriaId       Int
  score            Float
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  criteria         Criteria       @relation(fields: [criteriaId], references: [id])
  weeklyProgress   WeeklyProgress @relation(fields: [weeklyProgressId], references: [id], onDelete: Cascade)

  @@unique([weeklyProgressId, criteriaId])
}

model SawResult {
  id         Int      @id @default(autoincrement())
  studentId  Int
  period     String
  totalScore Float
  status     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, period])
}
