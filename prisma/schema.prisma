// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String   // bcrypt hashed
  role      String   // "admin" | "teacher"
  classId   String?  // Optional, links teacher to a class
  class     Class?   @relation("ClassTeachers", fields: [classId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Class {
  id        String    @id // e.g., "A", "B"
  name      String
  students  Student[]
  teachers  User[]    @relation("ClassTeachers")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Student {
  id          Int       @id @default(autoincrement())
  nis         String    @unique
  name        String
  gender      String?   // "L" | "P"
  dateOfBirth DateTime?
  parentName  String?
  parentPhone String?
  address     String?
  allergies   String?
  classId     String
  class       Class     @relation(fields: [classId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
